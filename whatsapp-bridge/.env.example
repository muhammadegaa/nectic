# Port (Railway sets this automatically)
PORT=3001

# Directory for Baileys session auth files — use Railway persistent volume
DATA_DIR=/data

# Nectic base URL — where messages are forwarded
NECTIC_BASE_URL=https://app.nectic.xyz

# Shared secret between Nectic (Next.js) and this bridge service
# Generate: openssl rand -hex 32
BRIDGE_SECRET=your_secret_here

# Firebase Admin SDK service account JSON (stringify the JSON, paste as single line)
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}
